{
  "name": "vibe-vscode",
  "displayName": "Vibe VS Code",
  "description": "VS Code extension for Vibe: a modern AI coding assistant with multi-provider support, agent mode, file operations, and enhanced UI.",
  "version": "3.0.0",
  "publisher": "mktech",
  "repository": {
    "type": "git",
    "url": "https://github.com/mk-knight23/vibe"
  },
  "bugs": {
    "url": "https://github.com/mk-knight23/vibe/issues"
  },
  "homepage": "https://github.com/mk-knight23/vibe#readme",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "keywords": [
    "ai",
    "artificial-intelligence",
    "openai",
    "chatgpt",
    "llm",
    "megallm",
    "openrouter",
    "assistant",
    "coding",
    "development",
    "productivity"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "rimraf dist && tsc -p ./tsconfig.json",
    "watch": "tsc -p ./tsconfig.json -w",
    "package": "vsce package",
    "lint": "echo \"No lint configured\""
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3",
    "rimraf": "^6.0.1",
    "vsce": "^2.15.0"
  },
  "dependencies": {},
  "activationEvents": [
    "onView:vibe.vibePanel",
    "onCommand:vibe.openChat",
    "onCommand:vibe.openAgent",
    "onCommand:vibe.openSettings",
    "onCommand:vibe.switchNextMode",
    "onCommand:vibe.switchPrevMode"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibe-sidebar",
          "title": "Vibe",
          "icon": "media/vibe-icon.svg"
        }
      ]
    },
    "views": {
      "vibe-sidebar": [
        {
          "type": "webview",
          "id": "vibe.vibePanel",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "vibe.openChat",
        "title": "Vibe: Open Chat",
        "category": "Vibe"
      },
      {
        "command": "vibe.openAgent",
        "title": "Vibe: Open Agent Panel",
        "category": "Vibe"
      },
      {
        "command": "vibe.openSettings",
        "title": "Vibe: Open Settings",
        "category": "Vibe"
      },
      {
        "command": "vibe.switchNextMode",
        "title": "Vibe: Next Mode (⌘+.)",
        "category": "Vibe"
      },
      {
        "command": "vibe.switchPrevMode",
        "title": "Vibe: Previous Mode (⌘+Shift+.)",
        "category": "Vibe"
      },
      {
        "command": "vibe.explainCode",
        "title": "Vibe: Explain Selected Code",
        "category": "Vibe"
      },
      {
        "command": "vibe.refactorCode",
        "title": "Vibe: Refactor Selected Code",
        "category": "Vibe"
      },
      {
        "command": "vibe.generateTests",
        "title": "Vibe: Generate Tests for Selection",
        "category": "Vibe"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vibe.explainCode",
          "when": "editorHasSelection",
          "group": "vibe@1"
        },
        {
          "command": "vibe.refactorCode",
          "when": "editorHasSelection",
          "group": "vibe@2"
        },
        {
          "command": "vibe.generateTests",
          "when": "editorHasSelection",
          "group": "vibe@3"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Vibe",
      "properties": {
        "vibe.openrouterApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your OpenRouter API key. Stored in VS Code settings (user or workspace). No login/signup flow is implemented."
        },
        "vibe.megallmApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your MegaLLM API key. Stored in VS Code settings (user or workspace)."
        },
        "vibe.provider": {
          "type": "string",
          "enum": ["openrouter", "megallm"],
          "default": "openrouter",
          "markdownDescription": "AI provider to use for chat and agent tasks. Choose between OpenRouter or MegaLLM."
        },
        "vibe.defaultModel": {
          "type": "string",
          "default": "z-ai/glm-4.5-air:free",
          "markdownDescription": "Default model id used for chat and agent tasks. Must be a valid model id for the selected provider."
        },
        "vibe.autoApproveUnsafeOps": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "If enabled, Vibe will auto-approve file edits, command execution and browser operations initiated from the agent. This is powerful and potentially dangerous."
        },
        "vibe.maxContextFiles": {
          "type": "number",
          "default": 20,
          "markdownDescription": "Maximum number of files to include when sending project context to the model."
        }
      }
    },
    "keybindings": [
      {
        "command": "vibe.switchNextMode",
        "key": "ctrl+.",
        "mac": "cmd+.",
        "when": "vibe:panelVisible"
      },
      {
        "command": "vibe.switchPrevMode",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "vibe:panelVisible"
      }
    ]
  }
}
